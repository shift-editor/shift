{
  "name": "@shift/types",
  "version": "0.0.1",
  "private": true,
  "description": "Shared TypeScript types for Shift font editor",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "generate:bridge-types": "node ../../scripts/generate-bridge-types.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@shift/tsconfig": "workspace:*",
    "typescript": "^5.5.4"
  }
}
