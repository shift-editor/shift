{
  "jsPlugins": ["oxlint-plugin-eslint"],
  "rules": {
    "eslint/no-unused-expressions": "off",
    "typescript/no-useless-empty-export": "off",
    "eslint/no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@shift/types/src/generated/*"],
            "message": "Import from @shift/types, not from generated/ directly."
          }
        ]
      }
    ],
    "eslint-js/no-restricted-syntax": [
      "error",
      {
        "selector": "ExpressionStatement > ChainExpression > CallExpression[optional=true]",
        "message": "Do not use foo?.() as a statement. Use an explicit guard: if (foo) foo();"
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/**/*.test.ts", "src/renderer/src/testing/**/*.ts"],
      "rules": {
        "typescript/no-explicit-any": "error"
      }
    }
  ]
}
